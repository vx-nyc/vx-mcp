# E2E test: run against a real VX API only (no mock server).
# Copy this file to test/.env.e2e and set credentials.
# test/.env.e2e is gitignored — never commit real production keys.
#
# For local dev: start VX (e.g. docker compose --profile dev up -d or npm run dev in vx/api),
# then use the seeded test user:
#   VX_API_BASE_URL=http://localhost:3000/v1
#   VX_BEARER_TOKEN=vx_test_local_00000000000000000000000000000000
#   VX_API_KEY=vx_test_local_00000000000000000000000000000000
#
# If these are not set, npm run test:e2e skips and exits 0.
VX_API_BASE_URL=http://localhost:3000/v1
VX_BEARER_TOKEN=
VX_API_KEY=
